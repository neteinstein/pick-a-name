<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PickAName" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#FF101418</item>
        <item name="android:statusBarColor">#FF002E51</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Same brand splash background in dark mode too — a splash screen is a transient, few
         hundred ms brand moment, so it deliberately stays on-brand rather than switching to a
         separate dark palette. -->
    <style name="Theme.PickAName.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF00599D</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.PickAName</item>
    </style>
</resources>

