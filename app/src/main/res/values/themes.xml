<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns all real theming (see presentation/theme). This just prevents a mismatched
         window background flash before the first Compose frame is drawn. -->
    <style name="Theme.PickAName" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#FFF7F9FC</item>
        <item name="android:statusBarColor">#FF00599D</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- System splash screen (androidx.core.splashscreen), shown for the brief moment between
         process start and the first Compose frame. Swaps to Theme.PickAName as soon as
         installSplashScreen() runs in MainActivity. The Compose SplashScreen takes over
         immediately after with the real animated brand moment. -->
    <style name="Theme.PickAName.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF00599D</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.PickAName</item>
    </style>
</resources>


